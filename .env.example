# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/rakel_investments?schema=public"

# ─────────────────────────────────────────────
# SUPABASE (required — lib/db/index.ts uses these for all DB reads/writes)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─────────────────────────────────────────────
# JWT / SESSION
# ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="0374e6ae58ce803d758bb77dbc4ebe91ed1cc1e438ce89b0a176403695d3f776b2e8a185e1a7ad2f6d947fe7f9ebe1328a3c22c83fa91497d77790aeb9f68a00"
JWT_EXPIRES_IN="8h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ─────────────────────────────────────────────
# SMTP / EMAIL (optional — registration approval emails are skipped if unset)
# ─────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@rakelinvestments.com"
